# =============================================================
# DB Chat AI — Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
# Quick start (local SQLite, ChromaDB, Gemini):
#   cp .env.example .env
#   # Set GEMINI_API_KEY, then:
#   uvicorn app.main:app --reload
# =============================================================

# ---- App -------------------------------------------------------
APP_ENV=local              # local | staging | production

# Generate a strong key:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# ---- Internal app database (users, schema versions, history)
# SQLite — zero setup, fine for development:
APP_DATABASE_URL=sqlite:///./app_dev.db
# PostgreSQL (docker-compose default):
# APP_DATABASE_URL=postgresql+psycopg://app_user:app_password@app-db:5432/chat_app

# ---- Target business database (what the AI queries)
# Leave empty to add via the Settings UI at runtime.
TARGET_DATABASE_URL=postgresql+psycopg://business_user:business_password@business-db:5432/business

# ---- CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000
# Production example:
# ALLOWED_ORIGINS=https://dbchat.yourcompany.com

# ---- LLM Provider -----------------------------------------------
LLM_PROVIDER=gemini            # gemini | openai
LLM_MODEL=gemini-2.5-flash

GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional — enables dollar-cost tracking in the Run Details panel
LLM_INPUT_COST_PER_1M_TOKENS=0
LLM_OUTPUT_COST_PER_1M_TOKENS=0

# ---- Embeddings --------------------------------------------------
EMBEDDING_MODEL=local-hashing  # local-hashing uses zero external calls

# ---- Vector Store ------------------------------------------------
VECTOR_DB_TYPE=chroma          # chroma | qdrant

# ChromaDB — local disk, used when VECTOR_DB_TYPE=chroma
CHROMA_PATH=/data/chroma

# Qdrant — used when VECTOR_DB_TYPE=qdrant
QDRANT_URL=http://qdrant:6333

# ---- SQL Safety --------------------------------------------------
MAX_SQL_ROWS=200
SQL_TIMEOUT_SECONDS=10
